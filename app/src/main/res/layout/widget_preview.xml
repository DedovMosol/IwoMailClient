<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1565C0">

    <!-- ══════════════════════════════════════ -->
    <!-- ВЕРХ — градиентная часть              -->
    <!-- ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp">

        <!-- Строка поиска (белая pill) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="#FFFFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/widget_search_mail"
            android:textColor="#FF757575"
            android:textSize="13sp" />

        <!-- Дата + непрочитанные -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Пн, 17 февраля"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 непрочитанных"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Нет событий -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Нет событий на сегодня"
            android:textColor="#99FFFFFF"
            android:textSize="10sp" />

        <!-- Задачи -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Задачи: 2  ·  Test"
            android:textColor="#CCFFFFFF"
            android:textSize="10sp" />

        <!-- Заметки -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Нет заметок"
            android:textColor="#99FFFFFF"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════ -->
    <!-- НИЗ — тёмный блок (письма + кнопки)  -->
    <!-- ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#E6181828"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Письмо 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="А. Иванов (16.02.2026)  Отчёт за..."
            android:textColor="#FFEEEEEE"
            android:textSize="10sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <!-- Письмо 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="М. Петрова (16.02.2026)  Встреча..."
            android:textColor="#B3EEEEEE"
            android:textSize="10sp"
            android:maxLines="1"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <!-- Письмо 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="С. Козлов (16.02.2026)  Документы..."
            android:textColor="#B3EEEEEE"
            android:textSize="10sp"
            android:maxLines="1"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <!-- Нижняя строка: аватар + время + кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Аватар -->
            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="#FF5C00D4"
                android:gravity="center"
                android:text="P"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Время синхронизации -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Только что"
                android:textColor="#80EEEEEE"
                android:textSize="9sp" />

            <!-- Кнопка Написать -->
            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#FF1565C0"
                android:gravity="center"
                android:text="E"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp" />

            <!-- Spacer -->
            <View
                android:layout_width="6dp"
                android:layout_height="1dp" />

            <!-- Кнопка Синхронизация -->
            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="#FF1565C0"
                android:gravity="center"
                android:text="S"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
